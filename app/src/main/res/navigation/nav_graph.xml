<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_create">

    <fragment
        android:id="@+id/navigation_create"
        android:name="com.simpleagenda.app.ui.create.CreateTaskFragment"
        android:label="Créer"
        tools:layout="@layout/fragment_create_task" />

    <fragment
        android:id="@+id/navigation_schedule"
        android:name="com.simpleagenda.app.ui.schedule.ScheduleFragment"
        android:label="Planifier"
        tools:layout="@layout/fragment_schedule" />

    <fragment
        android:id="@+id/navigation_select"
        android:name="com.simpleagenda.app.ui.select.SelectTaskFragment"
        android:label="Sélectionner"
        tools:layout="@layout/fragment_select_task" />

    <fragment
        android:id="@+id/navigation_unplanned"
        android:name="com.simpleagenda.app.ui.unplanned.UnplannedFragment"
        android:label="Non planifié"
        tools:layout="@layout/fragment_unplanned" />

    
</navigation>
