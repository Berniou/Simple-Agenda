<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SimpleAgenda" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/task_blue_light</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.SimpleAgenda.FullScreen" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/primary_dark</item>
    </style>
</resources>
