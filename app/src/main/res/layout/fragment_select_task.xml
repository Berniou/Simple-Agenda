<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.select.SelectTaskFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_4">

            <!-- Header -->
            <TextView
                style="@style/TextHeadlineMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_6"
                android:text="Sélectionner des tâches"
                android:textAlignment="center" />

            <!-- Selection Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_4"
                android:background="@color/surface_container_low"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_4">

                <TextView
                    android:id="@+id/text_selected_count"
                    style="@style/TextBodyMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Aucune tâche sélectionnée"
                    android:textColor="@color/on_surface_variant" />

            </LinearLayout>

            <!-- Task List -->
            <TextView
                style="@style/TextLabelMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_3"
                android:text="Tâches disponibles" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view_task_selection"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="@dimen/spacing_6"
                android:clipToPadding="false"
                tools:listitem="@layout/item_task_selection" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_clear_selection"
                    style="@style/SurfaceButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_3"
                    android:layout_weight="1"
                    android:text="Vider la sélection" />

                <Button
                    android:id="@+id/button_add_to_day"
                    style="@style/PrimaryButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_3"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:text="Ajouter à la journée" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
