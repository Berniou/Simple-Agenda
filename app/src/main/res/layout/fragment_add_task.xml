<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".ui.addtask.AddTaskFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_4">

        <!-- Header -->
        <TextView
            style="@style/TextHeadlineMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_6"
            android:text="@string/add_task" />

        <!-- Task Title -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_4"
            app:boxBackgroundColor="@color/surface_container_high"
            app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
            app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
            app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
            app:boxCornerRadiusTopStart="@dimen/corner_radius_md"
            app:boxStrokeWidth="0dp"
            app:hintTextColor="@color/on_surface_variant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/task_title"
                android:inputType="text"
                android:padding="@dimen/spacing_4" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Task Description -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_4"
            app:boxBackgroundColor="@color/surface_container_high"
            app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
            app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
            app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
            app:boxCornerRadiusTopStart="@dimen/corner_radius_md"
            app:boxStrokeWidth="0dp"
            app:hintTextColor="@color/on_surface_variant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_description"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="top"
                android:hint="@string/task_description"
                android:inputType="textMultiLine"
                android:padding="@dimen/spacing_4" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Time Selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_4"
            android:orientation="horizontal">

            <TextView
                style="@style/TextLabelMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_3"
                android:layout_weight="1"
                android:text="@string/task_time" />

            <TextView
                android:id="@+id/text_start_time"
                style="@style/TextBodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="@dimen/spacing_2"
                tools:text="09:00" />

            <TextView
                style="@style/TextBodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_2"
                android:text="—" />

            <TextView
                android:id="@+id/text_end_time"
                style="@style/TextBodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="@dimen/spacing_2"
                tools:text="10:00" />

        </LinearLayout>

        <!-- Category Selection -->
        <TextView
            style="@style/TextLabelMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3"
            android:text="@string/task_category" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_6"
            app:chipSpacingHorizontal="@dimen/spacing_2">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_blue"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="Blue"
                app:chipBackgroundColor="@color/task_blue" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_green"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="Green"
                app:chipBackgroundColor="@color/task_green" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_orange"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="Orange"
                app:chipBackgroundColor="@color/task_orange" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_6"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_cancel"
                style="@style/SurfaceButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_3"
                android:layout_weight="1"
                android:text="@string/cancel" />

            <Button
                android:id="@+id/button_save"
                style="@style/PrimaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_3"
                android:layout_weight="1"
                android:text="@string/save_task" />

        </LinearLayout>

        <!-- Delete Button (only visible in edit mode) -->
        <Button
            android:id="@+id/button_delete"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_4"
            android:text="@string/delete_task"
            android:textColor="@color/error"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
